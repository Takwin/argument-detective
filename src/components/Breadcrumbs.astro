---
import { withBase } from '../data/site';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="breadcrumbs page" aria-label="Breadcrumb">
  <ol>
    {
      items.map((item, i) => (
        <li>
          {item.href && i < items.length - 1 ? (
            <a href={withBase(item.href)}>{item.label}</a>
          ) : (
            <span aria-current="page">{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
