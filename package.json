{
  "name": "argument-detective",
  "version": "1.0.0",
  "description": "Argument Detective — a free, privacy-first field guide to 15 logical fallacies for gifted grades 5-6.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Roderic Rinehart",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run format:check && astro check && npm run test && npm run build"
  },
  "dependencies": {
    "astro": "^5.13.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.1",
    "js-yaml": "^4.1.0",
    "prettier": "^3.6.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "zod": "^3.25.0"
  }
}
